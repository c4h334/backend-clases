## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
.nuget/
*.nuget.props
*.nuget.targets

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
.vs/config/
iisexpress/

# Entity Framework
*.mdf
*.ldf

# SQL Server files
*.mdf
*.ldf

# Azure
PublishScripts/

# Logs
*.log
logs/

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
*.sln.iml

# DotCover
*.dotCover

# StyleCop
StyleCopReport.xml

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Coverlet
coverage.json
coverage.xml
coverage.info

# SonarQube
.sonarqube/

# Docker
docker-compose.override.yml

# Local environment files
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# Publish output
publish/

# Generated files
Generated/
wwwroot/lib/

# Secrets
secrets.json
appsettings.Development.json

# Certificates
*.pfx
*.snk

# Temporary files
*.tmp
*.temp
*.cache

# Node modules (if frontend included)
node_modules/

# Yarn / npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Terraform
.terraform/
*.tfstate
*.tfstate.*

# Mac/Linux hidden files
*.swp
*.swo
*~

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Backup files
*.bak
*.backup

# Paket dependency manager
.paket/
paket-files/

# FAKE
.fake/

# Local history
.localhistory/

# Cake
tools/**
!tools/packages.config